{
  "manifest_version": 3,
  "name": "Directory Crawler Pro (P2)",
  "version": "2.0.0",
  "description": "Durable-queue crawler with CDP rendered capture, full-page screenshots, and HTTP status tracking.",
  "minimum_chrome_version": "116",
  "permissions": ["storage", "unlimitedStorage", "offscreen", "alarms", "tabs", "scripting", "debugger"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": { "service_worker": "dist/background.js", "type": "module" },
  "action": {
    "default_popup": "dist/popup.html",
    "default_title": "Open Crawler Control Center",
    "default_icon": { "16": "dist/icons/16.png", "48": "dist/icons/48.png", "128": "dist/icons/128.png" }
  },
  "icons": { "16": "dist/icons/16.png", "48": "dist/icons/48.png", "128": "dist/icons/128.png" }
}
